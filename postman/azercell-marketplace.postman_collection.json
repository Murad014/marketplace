    {
      "name": "Inventory - Admin (Stock)",
      "description": "Stock is seeded automatically when a product is created (the variant's stockCount is seeded into the PRIMARY warehouse via an in-JVM event). Set a primary warehouse first (Warehouses -> Set Primary), then create a product, then run 'Get Product By Id (admin)' to capture variantId, then use the requests here. Restock/Adjust need warehouseId — set the {{warehouseId}} variable (e.g. via Create/Set-Primary warehouse) to the PRIMARY warehouse so it matches the seeded rows.",
      "item": [
        {
          "name": "Get Inventory By Variant",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/inventory?variantId={{variantId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "inventory" ],
              "query": [
                { "key": "variantId", "value": "{{variantId}}" }
              ]
            }
          }
        },
        {
          "name": "Restock (+amount)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"warehouseId\": \"{{warehouseId}}\",\n  \"variantId\": \"{{variantId}}\",\n  \"amount\": 15,\n  \"reference\": \"PO-2026-001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/inventory/restock",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "inventory", "restock" ]
            }
          }
        },
        {
          "name": "Adjust (set absolute quantity)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"warehouseId\": \"{{warehouseId}}\",\n  \"variantId\": \"{{variantId}}\",\n  \"newQuantity\": 30,\n  \"reference\": \"STOCKTAKE-Q2\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/inventory/adjust",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "inventory", "adjust" ]
            }
          }
        },
        {
          "name": "Get Movement Ledger",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/inventory/movements?variantId={{variantId}}&page=0&size=20",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "inventory", "movements" ],
              "query": [
                { "key": "variantId", "value": "{{variantId}}" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Financing - Credit Plans",
      "description": "Admin defines installment plans. The public 'Quote' endpoint computes monthly amounts for a price (storefront 'from X / month'). Interest is flat: interest = price x rate%, total = price + interest, monthly = total / months. type: DEFAULT = part of the standard offering, auto-applied to products that don't specify creditPlanIds; OPTIONAL = opt-in, only applied when a product explicitly lists it. The 5 standard plans (Full/3/6/9/12) are auto-seeded as DEFAULT on a fresh DB.",
      "item": [
        {
          "name": "Create Credit Plan",
          "description": "type: omit -> OPTIONAL (safe default); set DEFAULT to add the plan to the standard offering. This sample creates an OPTIONAL plan, so it will NOT auto-apply to products unless explicitly assigned via creditPlanIds.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "if (b && b.data && b.data.id) { pm.collectionVariables.set('creditPlanId', b.data.id); }",
                  "pm.test('201 Created', () => pm.response.code === 201);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"18 months special\",\n  \"months\": 18,\n  \"interestRate\": 8,\n  \"type\": \"OPTIONAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/credit-plans",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "credit-plans" ]
            }
          }
        },
        {
          "name": "List Credit Plans",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/credit-plans",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "credit-plans" ]
            }
          }
        },
        {
          "name": "Update Credit Plan",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"18 months special\",\n  \"months\": 18,\n  \"interestRate\": 7.5,\n  \"type\": \"OPTIONAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/credit-plans/{{creditPlanId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "credit-plans", "{{creditPlanId}}" ]
            }
          }
        },
        {
          "name": "Deactivate Credit Plan",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/credit-plans/{{creditPlanId}}/deactivate",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "credit-plans", "{{creditPlanId}}", "deactivate" ]
            }
          }
        },
        {
          "name": "Activate Credit Plan",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/credit-plans/{{creditPlanId}}/activate",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "credit-plans", "{{creditPlanId}}", "activate" ]
            }
          }
        },
        {
          "name": "Installment Quote (public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/credit-plans/quote?price=1200",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "credit-plans", "quote" ],
              "query": [
                { "key": "price", "value": "1200" }
              ]
            }
          }
        },
        {
          "name": "Get Order Credit (by order)",
          "description": "The financing agreement + installment schedule for an order (place an order WITH a creditPlanId first). Captures {{orderCreditId}} for the Pay request.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "if (b && b.data && b.data.id) { pm.collectionVariables.set('orderCreditId', b.data.id); console.log('orderCreditId =', b.data.id); }",
                  "pm.test('200 OK', () => pm.response.code === 200);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/order-credits?orderId={{orderId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "order-credits" ],
              "query": [
                { "key": "orderId", "value": "{{orderId}}" }
              ]
            }
          }
        },
        {
          "name": "Pay Next Installment",
          "description": "Settles the earliest unpaid installment. Repeat until status = COMPLETED; paying a completed credit -> 400 ORDER_CREDIT_NOT_ACTIVE.",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/order-credits/{{orderCreditId}}/pay",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "admin", "order-credits", "{{orderCreditId}}", "pay" ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "description": "Place an order from variant lines (no cart yet). Prereqs: a PRIMARY warehouse + a product with stock + run 'Catalog -> Get Product By Id (admin)' to capture {{variantId}}. Placing reserves stock (RESERVE); admin transitions drive the lifecycle (SHIPPED consumes stock = SALE; CANCELLED while still held releases = RELEASE). userId/changedBy are placeholders until the users context exists.",
      "item": [
        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "if (b && b.data && b.data.id) { pm.collectionVariables.set('orderId', b.data.id); console.log('orderId =', b.data.id); }",
                  "pm.test('201 Created', () => pm.response.code === 201);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"items\": [\n    { \"variantId\": \"{{variantId}}\", \"quantity\": 2 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "orders" ]
            }
          }
        },
        {
          "name": "Place Order (with installments)",
          "description": "Same as Place Order but chooses a credit plan -> financing opens an OrderCredit + monthly schedule on the order total. Run a 'Financing -> Create Credit Plan' (sets {{creditPlanId}}) or any active plan id first. Then use 'Financing -> Get Order Credit (by order)'.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "if (b && b.data && b.data.id) { pm.collectionVariables.set('orderId', b.data.id); }",
                  "pm.test('201 Created', () => pm.response.code === 201);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"creditPlanId\": \"{{creditPlanId}}\",\n  \"items\": [\n    { \"variantId\": \"{{variantId}}\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "orders" ]
            }
          }
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "orders", "{{orderId}}" ]
            }
          }
        },
        {
          "name": "List My Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders?userId={{userId}}&page=0&size=20",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "orders" ],
              "query": [
                { "key": "userId", "value": "{{userId}}" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "List All Orders (admin)",
          "request": {
            "method": "GET",
            "header": [],
